<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/styles/productDetail.css" />
</head>
<body>

  <%- include('../partials/header') %>


  <!-- ================================================
       BREADCRUMB
  ================================================ -->
  <div class="breadcrumb-wrapper">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/products">Productos</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current"><%= product.name %></span>
      </nav>
    </div>
  </div>


  <!-- ================================================
       DETALLE DEL PRODUCTO
  ================================================ -->
  <section class="section">
    <div class="container">
      <div class="product-detail-grid">

        <!-- ── Columna izquierda: Imágenes ── -->
        <div class="product-gallery">

          <!-- Imagen principal -->
          <div class="gallery-main">
            <img
              src="/images/products/<%= product.image %>"
              alt="<%= product.name %>"
              class="gallery-main-img"
              id="mainImage"
            />
          </div>

          <!-- Miniatura única (en Sprint 6 se pueden agregar múltiples imágenes) -->
          <div class="gallery-thumbs">
            <button class="thumb active" onclick="changeImage(this, '/images/products/<%= product.image %>')">
              <img src="/images/products/<%= product.image %>" alt="<%= product.name %>" />
            </button>
          </div>

        </div>

        <!-- ── Columna derecha: Info ── -->
        <div class="product-info">

          <!-- Categoría y nombre -->
          <p class="product-info-category"><%= product.category %></p>
          <h1 class="product-info-title"><%= product.name %></h1>
          <p class="product-info-sku text-muted">SKU: #<%= String(product.id).padStart(5, '0') %></p>

          <div class="product-info-divider"></div>

          <!-- Precio -->
          <div class="product-info-price">
            <span class="price-current">$<%= product.price.toLocaleString('es-AR') %></span>
          </div>

          <!-- Colores -->
          <% if (product.colors && product.colors.length > 0) { %>
          <p class="product-info-colors text-muted">
            Colores disponibles: <%= product.colors.join(', ') %>
          </p>
          <% } %>

          <div class="product-info-divider"></div>

          <!-- Descripción -->
          <div class="product-info-desc">
            <h3>Descripción</h3>
            <p><%= product.description %></p>
          </div>

          <div class="product-info-divider"></div>

          <!-- Cantidad -->
          <div class="product-quantity">
            <h3>Cantidad</h3>
            <div class="quantity-selector">
              <button class="qty-btn" onclick="changeQty(-1)">−</button>
              <input type="number" id="quantity" value="1" min="1" max="12" readonly />
              <button class="qty-btn" onclick="changeQty(1)">+</button>
            </div>
          </div>

          <!-- Botones de acción -->
          <div class="product-info-actions">
            <form action="/products/cart/add" method="POST" style="display:inline;">
              <input type="hidden" name="product_id" value="<%= product.id %>" />
              <button type="submit" class="btn btn-primary btn-lg">Agregar al carrito</button>
            </form>
            <% if (userLogged && (userLogged.role === 'admin' || userLogged.category === 'admin')) { %>
              <a href="/products/<%= product.id %>/edit" class="btn btn-secondary">Editar</a>
            <% } %>
          </div>

          <!-- Eliminar producto — solo admin -->
          <% if (userLogged && (userLogged.role === 'admin' || userLogged.category === 'admin')) { %>
          <form action="/products/<%= product.id %>?_method=DELETE" method="POST" style="margin-top: 1rem;">
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar este producto?')">
              Eliminar producto
            </button>
          </form>
          <% } %>

          <!-- Banner envío -->
          <div class="product-shipping">
            <div class="shipping-item">
              <span class="shipping-icon">🚚</span>
              <div>
                <p class="shipping-title">Envío gratis</p>
                <p class="shipping-sub">En compras mayores a $50.000</p>
              </div>
            </div>
            <div class="shipping-item">
              <span class="shipping-icon">📦</span>
              <div>
                <p class="shipping-title">Entrega estimada</p>
                <p class="shipping-sub">3 a 5 días hábiles</p>
              </div>
            </div>
            <div class="shipping-item">
              <span class="shipping-icon">🔄</span>
              <div>
                <p class="shipping-title">Devolución gratis</p>
                <p class="shipping-sub">Hasta 30 días después de la compra</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ================================================
       PRODUCTOS RELACIONADOS
  ================================================ -->
  <section class="section" style="background-color: var(--color-gray-100);">
    <div class="container">

      <div class="section-header">
        <h2 class="section-title">Productos <span>Relacionados</span></h2>
      </div>

      <div class="products-grid">

        <% if (relatedProducts.length > 0) { %>
          <% relatedProducts.forEach(related => { %>
          <div class="product-card">
            <div class="product-card-img-wrapper">
              <img src="/images/products/<%= related.image %>" alt="<%= related.name %>" class="product-card-img" />
            </div>
            <div class="product-card-body">
              <p class="product-card-category"><%= related.category ? related.category.name : '' %></p>
              <h3 class="product-card-name"><%= related.name %></h3>
              <div class="product-card-footer">
                <div class="product-card-price">$<%= Number(related.price).toLocaleString('es-AR') %></div>
                <a href="/products/<%= related.id %>" class="btn btn-primary btn-sm">Ver más</a>
              </div>
            </div>
          </div>
          <% }) %>
        <% } else { %>
          <p class="text-muted">No hay productos relacionados.</p>
        <% } %>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>


  <!-- ================================================
       JS — Cambio de imagen y cantidad
  ================================================ -->
  <script>
    function changeImage(thumb, src) {
      document.getElementById('mainImage').src = src;
      document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
    }

    function changeQty(delta) {
      const input = document.getElementById('quantity');
      const newVal = parseInt(input.value) + delta;
      if (newVal >= 1 && newVal <= 12) {
        input.value = newVal;
      }
    }
  </script>

</body>
</html>
