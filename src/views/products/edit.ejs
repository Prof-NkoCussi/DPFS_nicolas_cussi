<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/styles/forms.css" />
</head>
<body>

  <%- include('../partials/header') %>


  <!-- ================================================
       BREADCRUMB
  ================================================ -->
  <div class="breadcrumb-wrapper">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/products">Productos</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/products/<%= product.id %>"><%= product.name %></a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Editar producto</span>
      </nav>
    </div>
  </div>


  <!-- ================================================
       FORMULARIO EDITAR PRODUCTO
  ================================================ -->
  <section class="auth-section">
    <div class="container">

      <div class="auth-card">

        <!-- Encabezado -->
        <div class="auth-header">
          <div class="auth-logo">✏️</div>
          <h1 class="auth-title">Editar producto</h1>
          <p class="auth-subtitle">Modificá los datos del producto y guardá los cambios</p>
        </div>

        <!-- Flash messages backend -->
        <% if (errorMsg && errorMsg.length > 0) { %>
          <div class="form-alert error">
            <% errorMsg.forEach(msg => { %>
              <p>⚠️ <%= msg %></p>
            <% }) %>
          </div>
        <% } %>

        <!-- Formulario -->
        <form class="auth-form" action="/products/<%= product.id %>?_method=PUT" method="POST" id="editForm" novalidate>

          <!-- Nombre -->
          <div class="form-group">
            <label class="form-label" for="name">Nombre del producto</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="Ej: Guitarra Eléctrica Pro"
              value="<%= product.name %>"
            />
            <span class="form-error" id="nameError"></span>
          </div>

          <!-- Precio -->
          <div class="form-group">
            <label class="form-label" for="price">Precio ($)</label>
            <input
              type="number"
              id="price"
              name="price"
              class="form-input"
              placeholder="Ej: 89999"
              min="0"
              value="<%= product.price %>"
            />
            <span class="form-error" id="priceError"></span>
          </div>

          <!-- Categoría -->
          <div class="form-group">
            <label class="form-label" for="category_id">Categoría</label>
            <select id="category_id" name="category_id" class="form-input">
              <option value="" disabled>Seleccioná una categoría</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= product.category_id === cat.id ? 'selected' : '' %>>
                  <%= cat.name.charAt(0).toUpperCase() + cat.name.slice(1) %>
                </option>
              <% }) %>
            </select>
            <span class="form-error" id="categoryError"></span>
          </div>

          <!-- Descripción -->
          <div class="form-group">
            <label class="form-label" for="description">Descripción</label>
            <textarea
              id="description"
              name="description"
              class="form-input"
              placeholder="Describí las características del producto..."
              rows="4"
            ><%= product.description %></textarea>
            <span class="form-error" id="descriptionError"></span>
          </div>

          <!-- Imagen -->
          <div class="form-group">
            <label class="form-label" for="image">Imagen (nombre del archivo)</label>
            <input
              type="text"
              id="image"
              name="image"
              class="form-input"
              placeholder="Ej: guitarra-001.png"
              value="<%= product.image %>"
            />
            <span class="form-hint">El archivo debe estar en la carpeta public/images/products/</span>
            <span class="form-error" id="imageError"></span>
          </div>

          <!-- Colores -->
          <div class="form-group">
            <label class="form-label" for="colors">Colores disponibles</label>
            <input
              type="text"
              id="colors"
              name="colors"
              class="form-input"
              placeholder="Ej: negro, rojo, azul"
              value="<%= product.colors ? product.colors.join(', ') : '' %>"
            />
            <span class="form-hint">Separalos con coma</span>
          </div>

          <!-- Botones -->
          <div class="form-actions">
            <a href="/products/<%= product.id %>" class="btn btn-secondary btn-lg">
              Cancelar
            </a>
            <button type="submit" class="btn btn-primary btn-lg">
              Guardar cambios
            </button>
          </div>

          <!-- Mensaje de error general -->
          <div class="form-alert error" id="formError" style="display:none;">
            ⚠️ Por favor corregí los errores antes de continuar.
          </div>

          <!-- Mensaje de éxito -->
          <div class="form-alert success" id="formSuccess" style="display:none;">
            ✅ ¡Producto actualizado con éxito! Redirigiendo...
          </div>

        </form>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>


  <!-- ================================================
       JS — Validación básica
  ================================================ -->
  <script>
    document.getElementById('editForm').addEventListener('submit', function(e) {

      let valid = true;

      // Limpiar errores previos
      ['name', 'price', 'category_id', 'description'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.classList.remove('error');
      });
      ['nameError', 'priceError', 'categoryError', 'descriptionError'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '';
      });
      document.getElementById('formError').style.display   = 'none';
      document.getElementById('formSuccess').style.display = 'none';

      // Nombre — obligatorio y mínimo 5 caracteres
      const name = document.getElementById('name');
      if (!name.value.trim()) {
        name.classList.add('error');
        document.getElementById('nameError').textContent = 'El nombre es obligatorio.';
        valid = false;
      } else if (name.value.trim().length < 5) {
        name.classList.add('error');
        document.getElementById('nameError').textContent = 'El nombre debe tener al menos 5 caracteres.';
        valid = false;
      }

      // Precio — obligatorio y mayor a 0
      const price = document.getElementById('price');
      if (!price.value) {
        price.classList.add('error');
        document.getElementById('priceError').textContent = 'El precio es obligatorio.';
        valid = false;
      } else if (parseFloat(price.value) <= 0) {
        price.classList.add('error');
        document.getElementById('priceError').textContent = 'El precio debe ser mayor a 0.';
        valid = false;
      }

      // Categoría — obligatoria
      const category = document.getElementById('category_id');
      if (!category.value) {
        category.classList.add('error');
        document.getElementById('categoryError').textContent = 'Seleccioná una categoría.';
        valid = false;
      }

      // Descripción — obligatoria y mínimo 20 caracteres
      const desc = document.getElementById('description');
      if (!desc.value.trim()) {
        desc.classList.add('error');
        document.getElementById('descriptionError').textContent = 'La descripción es obligatoria.';
        valid = false;
      } else if (desc.value.trim().length < 20) {
        desc.classList.add('error');
        document.getElementById('descriptionError').textContent = 'La descripción debe tener al menos 20 caracteres.';
        valid = false;
      }

      if (!valid) {
        e.preventDefault();
        document.getElementById('formError').style.display = 'block';
      }
    });
  </script>

</body>
</html>
