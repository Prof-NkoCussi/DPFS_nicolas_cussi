<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
</head>
<body>

  <%- include('../partials/header') %>


  <!-- ================================================
       BREADCRUMB
  ================================================ -->
  <div class="breadcrumb-wrapper">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Productos</span>
      </nav>
    </div>
  </div>


  <!-- ================================================
       LISTADO DE PRODUCTOS
  ================================================ -->
  <section class="section">
    <div class="container">

      <div class="section-header">
        <h1 class="section-title">Todos los <span>Productos</span></h1>
        <a href="/products/create" class="btn btn-primary btn-sm">+ Agregar producto</a>
      </div>

      <div class="products-grid">

        <% products.forEach(product => { %>
        <div class="product-card">
          <div class="product-card-img-wrapper">
            <img src="/images/products/<%= product.image %>" alt="<%= product.name %>" class="product-card-img" />
          </div>
          <div class="product-card-body">
            <p class="product-card-category"><%= product.category ? product.category.name : '' %></p>
            <h3 class="product-card-name"><%= product.name %></h3>
            <div class="product-card-footer">
              <div class="product-card-price"><%- formatPrice(product.price) %></div>
              <a href="/products/<%= product.id %>" class="btn btn-primary btn-sm">Ver más</a>
            </div>
          </div>
        </div>
        <% }) %>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>

</body>
</html>
