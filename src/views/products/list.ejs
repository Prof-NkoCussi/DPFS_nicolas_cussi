            <div class="product-card-footer">
              <div class="product-card-price">$72.500</div>
              <a href="/products/6" class="btn btn-primary btn-sm">Ver más</a>
            </div>
          </div>
        </div>

        <!-- Producto 7 -->
        <div class="product-card">
          <div class="product-card-img-wrapper">
            <img src="/images/products/pedal-01.png" alt="Pedal de Efectos" class="product-card-img" />
          </div>
          <div class="product-card-body">
            <p class="product-card-category">Accesorios</p>
            <h3 class="product-card-name">Pedal de Efectos Multi-FX</h3>
            <div class="product-card-rating">
              <span class="stars">★★★★☆</span>
              <span class="text-muted">(15)</span>
            </div>
            <div class="product-card-footer">
              <div class="product-card-price">$38.000</div>
              <a href="/products/7" class="btn btn-primary btn-sm">Ver más</a>
            </div>
          </div>
        </div>

        <!-- Producto 8 -->
        <div class="product-card">
          <div class="product-card-img-wrapper">
            <img src="/images/products/teclado-02.png" alt="Teclado Arranger" class="product-card-img" />
          </div>
          <div class="product-card-body">
            <p class="product-card-category">Teclados</p>
            <h3 class="product-card-name">Teclado Arranger 76 Teclas</h3>
            <div class="product-card-rating">
              <span class="stars">★★★★☆</span>
              <span class="text-muted">(9)</span>
            </div>
            <div class="product-card-footer">
              <div class="product-card-price">$98.000</div>
              <a href="/products/8" class="btn btn-primary btn-sm">Ver más</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>

</body>
</html>
