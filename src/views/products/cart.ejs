<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/styles/productCart.css" />
</head>
<body>

  <%- include('../partials/header') %>

  <div class="breadcrumb-wrapper">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Carrito de compras</span>
      </nav>
    </div>
  </div>

  <section class="section">
    <div class="container">

      <div class="cart-header">
        <h1 class="cart-title">Carrito de <span>Compras</span></h1>
        <p class="text-muted"><%= cart.length %> producto<%= cart.length !== 1 ? 's' : '' %> en tu carrito</p>
      </div>

      <% if (cart.length === 0) { %>
        <div style="text-align:center; padding: 4rem 0;">
          <p style="font-size:1.2rem; color: var(--color-text-muted);">Tu carrito está vacío.</p>
          <a href="/products" class="btn btn-primary" style="margin-top:1rem;">Ver productos</a>
        </div>

      <% } else { %>
      <div class="cart-layout">

        <!-- Columna izquierda: Productos -->
        <div class="cart-items">

          <div class="cart-table-header">
            <span class="col-product">Producto</span>
            <span class="col-price">Precio</span>
            <span class="col-qty">Cantidad</span>
            <span class="col-subtotal">Subtotal</span>
          </div>

          <% cart.forEach(item => { %>
          <div class="cart-item">
            <div class="cart-item-product">
              <a href="/products/<%= item.id %>">
                <img src="/images/products/<%= item.image %>" alt="<%= item.name %>" class="cart-item-img" onerror="this.src='/images/products/default-product.png'" />
              </a>
              <div class="cart-item-info">
                <a href="/products/<%= item.id %>" class="cart-item-name"><%= item.name %></a>
                <form action="/products/cart/remove" method="POST" style="display:inline;">
                  <input type="hidden" name="product_id" value="<%= item.id %>" />
                  <button type="submit" class="cart-item-remove">🗑 Eliminar</button>
                </form>
              </div>
            </div>

            <div class="cart-item-price">$<%= item.price.toLocaleString('es-AR') %></div>

            <div class="cart-item-qty">
              <form action="/products/cart/update" method="POST" class="quantity-selector">
                <input type="hidden" name="product_id" value="<%= item.id %>" />
                <button type="submit" name="quantity" value="<%= item.quantity - 1 %>" class="qty-btn">−</button>
                <input type="number" value="<%= item.quantity %>" min="1" max="12" readonly />
                <button type="submit" name="quantity" value="<%= item.quantity + 1 %>" class="qty-btn">+</button>
              </form>
            </div>

            <div class="cart-item-subtotal">$<%= (item.price * item.quantity).toLocaleString('es-AR') %></div>
          </div>
          <% }) %>

          <div class="cart-actions">
            <a href="/products" class="btn btn-secondary btn-sm">← Seguir comprando</a>
            <form action="/products/cart/clear" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-danger btn-sm">🗑 Vaciar carrito</button>
            </form>
          </div>

          <div class="cart-coupon">
            <h3>¿Tenés un cupón de descuento?</h3>
            <div class="coupon-form">
              <input type="text" class="form-input" id="couponInput" placeholder="Ingresá tu código aquí" />
              <button class="btn btn-dark" onclick="applyCoupon()">Aplicar</button>
            </div>
            <p class="coupon-msg" id="couponMsg"></p>
          </div>

        </div>

        <!-- Columna derecha: Resumen -->
        <div class="cart-summary">
          <h2 class="cart-summary-title">Resumen del pedido</h2>

          <div class="cart-summary-rows">
            <div class="summary-row">
              <span>Subtotal (<%= cartCount %> items)</span>
              <span>$<%= total.toLocaleString('es-AR') %></span>
            </div>
            <div class="summary-row">
              <span>Envío</span>
              <span class="text-success">Gratis 🚚</span>
            </div>
          </div>

          <div class="cart-summary-divider"></div>

          <div class="summary-total">
            <span>Total</span>
            <span>$<%= total.toLocaleString('es-AR') %></span>
          </div>

          <a href="#" class="btn btn-primary btn-lg btn-full">Finalizar compra</a>
          <a href="/products" class="cart-summary-back">← Seguir comprando</a>

          <div class="payment-methods">
            <p class="payment-label">Métodos de pago aceptados</p>
            <div class="payment-badges">
              <span class="payment-badge">VISA</span>
              <span class="payment-badge">MASTER</span>
              <span class="payment-badge">AMEX</span>
              <span class="payment-badge">PAYPAL</span>
            </div>
          </div>
        </div>

      </div>
      <% } %>

    </div>
  </section>

  <%- include('../partials/footer') %>

  <script>
    function applyCoupon() {
      const code = document.getElementById('couponInput').value.trim().toUpperCase();
      const msg  = document.getElementById('couponMsg');
      if (code === 'MUSIC10') {
        msg.textContent = '✅ Cupón aplicado — 10% de descuento';
        msg.style.color = 'var(--color-success)';
      } else {
        msg.textContent = '❌ Cupón inválido o expirado';
        msg.style.color = 'var(--color-danger)';
      }
    }
  </script>

</body>
</html>
