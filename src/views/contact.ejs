<%- include('partials/head', { title: 'Contacto — Ushuaia MusicStore' }) %>
<%- include('partials/header') %>

<main class="contact-page">
  <div class="container">

    <div class="contact-card">

      <div class="contact-header">
        <h1>🎸 Ushuaia <span>MusicStore</span></h1>
        <p>¿Tenés alguna consulta? Estamos para ayudarte.</p>
      </div>

      <div class="contact-items">

        <div class="contact-item">
          <span class="contact-icon">📍</span>
          <div>
            <h3>Dirección</h3>
            <p>Ushuaia, Tierra del Fuego, Argentina</p>
          </div>
        </div>

        <div class="contact-item">
          <span class="contact-icon">📞</span>
          <div>
            <h3>Teléfono</h3>
            <p>+542901634802</p>
          </div>
        </div>

        <div class="contact-item">
          <span class="contact-icon">✉️</span>
          <div>
            <h3>Email</h3>
            <p>info@ushuaiamusicstore.com</p>
          </div>
        </div>

        <div class="contact-item">
          <span class="contact-icon">🕐</span>
          <div>
            <h3>Horario de atención</h3>
            <p>Lunes a Viernes — 9:00 a 18:00 hs</p>
            <p>Sábados — 10:00 a 14:00 hs</p>
          </div>
        </div>

        <div class="contact-item">
          <span class="contact-icon">📱</span>
          <div>
            <h3>Redes sociales</h3>
            <p>Facebook · Instagram · YouTube</p>
          </div>
        </div>

      </div>

      <div class="contact-footer">
        <a href="/" class="btn btn-primary">← Volver al inicio</a>
      </div>

    </div>

  </div>
</main>

<style>
.contact-page {
  min-height: 70vh;
  display: flex;
  align-items: center;
  padding: 3rem 0;
  background: #f8f9fa;
}

.contact-card {
  max-width: 600px;
  margin: 0 auto;
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  padding: 3rem;
  text-align: center;
}

.contact-header h1 {
  font-size: 2rem;
  color: var(--dark);
  margin-bottom: 0.5rem;
}

.contact-header h1 span { color: var(--primary); }

.contact-header p {
  color: #718096;
  margin-bottom: 2rem;
}

.contact-items {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  text-align: left;
  margin-bottom: 2rem;
}

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1rem 1.2rem;
  background: #f8f9fa;
  border-radius: 10px;
}

.contact-icon { font-size: 1.8rem; }

.contact-item h3 {
  font-size: 0.85rem;
  color: #718096;
  margin-bottom: 0.2rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.contact-item p {
  color: var(--dark);
  font-size: 0.95rem;
  margin: 0;
}

.contact-footer { text-align: center; }
</style>

<%- include('partials/footer') %>
