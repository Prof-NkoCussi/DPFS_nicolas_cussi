<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/styles/forms.css" />
</head>
<body>

  <%- include('../partials/header') %>


  <!-- ================================================
       SECCIÓN REGISTRO
  ================================================ -->
  <section class="auth-section">
    <div class="container">

      <div class="auth-card">

        <!-- Encabezado -->
        <div class="auth-header">
          <h1 class="auth-title">Crear una cuenta</h1>
          <p class="auth-subtitle">Completá tus datos para registrarte en Ushuaia MusicStore</p>
        </div>

        <!-- Mensajes flash del servidor -->
        <% if (errorMsg && errorMsg.length > 0) { %>
          <div class="form-alert error"><%= errorMsg[0] %></div>
        <% } %>
        <% if (successMsg && successMsg.length > 0) { %>
          <div class="form-alert success"><%= successMsg[0] %></div>
        <% } %>

        <!-- Formulario -->
        <form class="auth-form" action="/users/register" method="POST" enctype="multipart/form-data" id="registerForm" novalidate>

          <!-- Fila: Nombre y Apellido -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="firstName">Nombre</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                class="form-input"
                placeholder="Tu nombre"
                autocomplete="given-name"
              />
              <span class="form-error" id="firstNameError"></span>
            </div>
            <div class="form-group">
              <label class="form-label" for="lastName">Apellido</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                class="form-input"
                placeholder="Tu apellido"
                autocomplete="family-name"
              />
              <span class="form-error" id="lastNameError"></span>
            </div>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label class="form-label" for="email">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="ejemplo@email.com"
              autocomplete="email"
            />
            <span class="form-error" id="emailError"></span>
          </div>

          <!-- Teléfono -->
          <div class="form-group">
            <label class="form-label" for="phone">Teléfono</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              placeholder="+54 11 0000-0000"
              autocomplete="tel"
            />
            <span class="form-error" id="phoneError"></span>
          </div>

          <!-- Fecha de nacimiento -->
          <div class="form-group">
            <label class="form-label" for="birthdate">Fecha de nacimiento</label>
            <input
              type="date"
              id="birthdate"
              name="birthdate"
              class="form-input"
              autocomplete="bday"
            />
            <span class="form-error" id="birthdateError"></span>
          </div>

          <!-- Separador seguridad -->
          <div class="form-section-label">
            <span>Seguridad</span>
          </div>

          <!-- Contraseña -->
          <div class="form-group">
            <label class="form-label" for="password">Contraseña</label>
            <div class="input-password-wrapper">
              <input
                type="password"
                id="password"
                name="password"
                class="form-input"
                placeholder="Mínimo 8 caracteres"
                oninput="checkStrength(this.value)"
                autocomplete="new-password"
              />
              <button type="button" class="toggle-password" onclick="togglePassword('password', this)">👁</button>
            </div>
            <div class="strength-bar">
              <div class="strength-track">
                <div class="strength-fill" id="strengthFill"></div>
              </div>
              <span class="strength-label" id="strengthLabel"></span>
            </div>
            <span class="form-error" id="passwordError"></span>
          </div>

          <!-- Confirmar contraseña -->
          <div class="form-group">
            <label class="form-label" for="confirmPassword">Confirmar contraseña</label>
            <div class="input-password-wrapper">
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                class="form-input"
                placeholder="Repetí tu contraseña"
                autocomplete="new-password"
              />
              <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword', this)">👁</button>
            </div>
            <span class="form-error" id="confirmPasswordError"></span>
          </div>

          <!-- Foto de perfil -->
          <div class="form-group">
            <label class="form-label" for="image">Foto de perfil (opcional)</label>
            <input
              type="file"
              id="image"
              name="image"
              class="form-input"
              accept=".jpg,.jpeg,.png,.gif"
            />
            <span class="form-hint">JPG, JPEG, PNG o GIF. Si no subís una, se usará la imagen por defecto.</span>
          </div>

          <!-- Checkboxes -->
          <div class="form-checks">
            <label class="form-check">
              <input type="checkbox" id="terms" name="terms" />
              Acepto los <a href="#" class="form-link">Términos y Condiciones</a> y la <a href="#" class="form-link">Política de Privacidad</a>
            </label>
            <span class="form-error" id="termsError"></span>

            <label class="form-check">
              <input type="checkbox" id="newsletter" name="newsletter" />
              Quiero recibir ofertas y novedades por email
            </label>
          </div>

          <!-- Botón registrarse -->
          <button type="submit" class="btn btn-primary btn-lg btn-full">
            Crear cuenta
          </button>

          <!-- Mensaje de error general -->
          <div class="form-alert error" id="formError" style="display:none;">
            ⚠️ Por favor corregí los errores antes de continuar.
          </div>

          <!-- Mensaje de éxito -->
          <div class="form-alert success" id="formSuccess" style="display:none;">
            ✅ ¡Cuenta creada con éxito! Redirigiendo...
          </div>

        </form>

        <!-- Divider social -->
        <div class="divider">o registrate con</div>

        <div class="social-buttons">
          <button class="btn-social">
            <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" width="20" />
            Continuar con Google
          </button>
          <button class="btn-social">
            <img src="https://www.svgrepo.com/show/448224/facebook.svg" alt="Facebook" width="20" />
            Continuar con Facebook
          </button>
        </div>

        <!-- Link login -->
        <p class="auth-switch">
          ¿Ya tenés cuenta? <a href="/users/login" class="form-link">Iniciá sesión aquí</a>
        </p>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>


  <!-- ================================================
       JS — Validación del formulario
  ================================================ -->
  <script>
    function togglePassword(id, btn) {
      const input = document.getElementById(id);
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
      } else {
        input.type = 'password';
        btn.textContent = '👁';
      }
    }

    function checkStrength(value) {
      const fill  = document.getElementById('strengthFill');
      const label = document.getElementById('strengthLabel');
      let strength = 0;
      if (value.length >= 8)          strength++;
      if (/[A-Z]/.test(value))        strength++;
      if (/[0-9]/.test(value))        strength++;
      if (/[^A-Za-z0-9]/.test(value)) strength++;

      const levels = [
        { color: '#e63946', text: 'Muy débil', width: '25%' },
        { color: '#f4a022', text: 'Débil',     width: '50%' },
        { color: '#00c2b8', text: 'Buena',     width: '75%' },
        { color: '#28a745', text: 'Fuerte',    width: '100%' },
      ];

      if (value.length === 0) {
        fill.style.width = '0%';
        label.textContent = '';
        return;
      }

      const level = levels[strength - 1] || levels[0];
      fill.style.width           = level.width;
      fill.style.backgroundColor = level.color;
      label.textContent          = level.text;
      label.style.color          = level.color;
    }

    document.getElementById('registerForm').addEventListener('submit', function(e) {
      let valid = true;

      const fields = [
        { id: 'firstName',       errorId: 'firstNameError',       msg: 'El nombre es obligatorio.' },
        { id: 'lastName',        errorId: 'lastNameError',        msg: 'El apellido es obligatorio.' },
        { id: 'email',           errorId: 'emailError',           msg: 'El email es obligatorio.' },
        { id: 'phone',           errorId: 'phoneError',           msg: 'El teléfono es obligatorio.' },
        { id: 'birthdate',       errorId: 'birthdateError',       msg: 'La fecha de nacimiento es obligatoria.' },
        { id: 'password',        errorId: 'passwordError',        msg: 'La contraseña es obligatoria.' },
        { id: 'confirmPassword', errorId: 'confirmPasswordError', msg: 'Confirmá tu contraseña.' },
      ];

      fields.forEach(f => {
        document.getElementById(f.id).classList.remove('error');
        document.getElementById(f.errorId).textContent = '';
      });
      document.getElementById('termsError').textContent    = '';
      document.getElementById('formError').style.display   = 'none';
      document.getElementById('formSuccess').style.display = 'none';

      fields.forEach(f => {
        const input = document.getElementById(f.id);
        if (!input.value.trim()) {
          input.classList.add('error');
          document.getElementById(f.errorId).textContent = f.msg;
          valid = false;
        }
      });

      // Nombre mínimo 2 caracteres
      const firstNameInput = document.getElementById('firstName');
      if (firstNameInput.value.trim() && firstNameInput.value.trim().length < 2) {
        firstNameInput.classList.add('error');
        document.getElementById('firstNameError').textContent = 'El nombre debe tener al menos 2 caracteres.';
        valid = false;
      }

      // Apellido mínimo 2 caracteres
      const lastNameInput = document.getElementById('lastName');
      if (lastNameInput.value.trim() && lastNameInput.value.trim().length < 2) {
        lastNameInput.classList.add('error');
        document.getElementById('lastNameError').textContent = 'El apellido debe tener al menos 2 caracteres.';
        valid = false;
      }

      // Email formato válido
      const emailInput = document.getElementById('email');
      if (emailInput.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
        emailInput.classList.add('error');
        document.getElementById('emailError').textContent = 'Ingresá un email válido.';
        valid = false;
      }

      // Contraseña mínimo 8 caracteres
      const passInput = document.getElementById('password');
      if (passInput.value && passInput.value.length < 8) {
        passInput.classList.add('error');
        document.getElementById('passwordError').textContent = 'La contraseña debe tener al menos 8 caracteres.';
        valid = false;
      }

      // Confirmar contraseña coincide
      const pass    = passInput.value;
      const confirm = document.getElementById('confirmPassword').value;
      if (pass && confirm && pass !== confirm) {
        document.getElementById('confirmPassword').classList.add('error');
        document.getElementById('confirmPasswordError').textContent = 'Las contraseñas no coinciden.';
        valid = false;
      }

      // Imagen formato válido
      const imageInput = document.getElementById('image');
      if (imageInput.files && imageInput.files[0]) {
        const fileName = imageInput.files[0].name.toLowerCase();
        if (!/\.(jpg|jpeg|png|gif)$/.test(fileName)) {
          imageInput.classList.add('error');
          valid = false;
          document.getElementById('formError').style.display = 'block';
          document.getElementById('formError').textContent = '⚠️ La imagen debe ser JPG, JPEG, PNG o GIF.';
        }
      }

      // Términos y condiciones
      if (!document.getElementById('terms').checked) {
        document.getElementById('termsError').textContent = 'Debés aceptar los términos y condiciones.';
        valid = false;
      }

      if (!valid) {
        e.preventDefault();
        document.getElementById('formError').style.display = 'block';
      }
    });
  </script>

</body>
</html>
