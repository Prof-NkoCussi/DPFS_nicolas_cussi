<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/styles/forms.css" />
</head>
<body>

  <%- include('../partials/header') %>


  <!-- ================================================
       BREADCRUMB
  ================================================ -->
  <div class="breadcrumb-wrapper">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">Mi perfil</span>
      </nav>
    </div>
  </div>


  <!-- ================================================
       PERFIL DEL USUARIO
  ================================================ -->
  <section class="auth-section">
    <div class="container">

      <div class="auth-card">

        <!-- Mensajes flash -->
        <% if (errorMsg && errorMsg.length > 0) { %>
          <div class="form-alert error"><%= errorMsg[0] %></div>
        <% } %>
        <% if (successMsg && successMsg.length > 0) { %>
          <div class="form-alert success"><%= successMsg[0] %></div>
        <% } %>

        <!-- Avatar y nombre -->
        <div class="auth-header">
          <img
            src="/images/users/<%= userLogged.image %>"
            alt="<%= userLogged.firstName %>"
            class="profile-avatar"
            onerror="this.src='/images/users/user-default.png'"
          />
          <h1 class="auth-title"><%= userLogged.firstName %> <%= userLogged.lastName %></h1>
          <p class="auth-subtitle"><%= userLogged.email %></p>
          <span class="badge <%= userLogged.category === 'admin' ? 'badge-danger' : 'badge-turquoise' %>">
            <%= userLogged.category === 'admin' ? 'Administrador' : 'Usuario' %>
          </span>
        </div>

        <!-- Datos del perfil -->
        <div class="profile-data">
          <div class="profile-row">
            <span class="profile-label">Nombre</span>
            <span class="profile-value"><%= userLogged.firstName %> <%= userLogged.lastName %></span>
          </div>
          <div class="profile-row">
            <span class="profile-label">Email</span>
            <span class="profile-value"><%= userLogged.email %></span>
          </div>
          <div class="profile-row">
            <span class="profile-label">Rol</span>
            <span class="profile-value"><%= userLogged.category %></span>
          </div>
        </div>

        <!-- Acciones -->
        <div style="display:flex; flex-direction:column; gap:0.75rem; margin-top:2rem;">
          <% if (userLogged.category === 'admin') { %>
            <a href="/products/create" class="btn btn-primary btn-lg btn-full">Agregar producto</a>
            <a href="/products" class="btn btn-secondary btn-lg btn-full">Ver productos</a>
          <% } else { %>
            <a href="/products" class="btn btn-primary btn-lg btn-full">Ver productos</a>
          <% } %>
          <a href="/users/logout" class="btn btn-danger btn-lg btn-full">Cerrar sesión</a>
        </div>

      </div>
    </div>
  </section>


  <%- include('../partials/footer') %>

</body>
</html>
