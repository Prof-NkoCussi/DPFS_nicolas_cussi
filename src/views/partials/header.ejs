<!-- PARTIAL: header.ejs -->

<header class="navbar">
  <div class="container">

    <a href="/" class="navbar-brand">
      <span class="brand-name">USHUAIA <span class="brand-accent">MUSIC</span>STORE</span>
    </a>

    <!-- Nav links -->
    <nav class="navbar-nav">
      <a href="/" class="nav-link">Inicio</a>

      <!-- Dropdown Categorías -->
      <div class="nav-dropdown">
        <a href="#" class="nav-link">Categorías ▾</a>
        <div class="nav-dropdown-menu">
          <a href="/products?category=guitarras">Guitarras</a>
          <a href="/products?category=teclados">Teclados</a>
          <a href="/products?category=baterias">Baterías</a>
          <a href="/products?category=microfonos">Micrófonos</a>
          <a href="/products?category=accesorios">Accesorios</a>
        </div>
      </div>

      <a href="/products" class="nav-link">Productos</a>
      <a href="/contact" class="nav-link">Contacto</a>
    </nav>

    <!-- Acciones -->
    <div class="navbar-actions">

      <% if (userLogged) { %>
        <!-- Usuario logueado -->
        <div class="nav-dropdown">
          <a href="#" class="navbar-login">
            <img src="/images/users/<%= userLogged.image %>" alt="<%= userLogged.firstName %>" class="navbar-avatar" onerror="this.src='/images/users/user-default.png'" />
            <%= userLogged.firstName %>  ▾
          </a>
          <div class="nav-dropdown-menu">
            <a href="/users/profile">Mi perfil</a>
            <% if (userLogged.role === 'admin') { %>
              <a href="/products/create">Agregar producto</a>
            <% } %>
            <a href="/users/logout">Cerrar sesión</a>
          </div>
        </div>
      <% } else { %>
        <!-- Sin sesión -->
        <a href="/users/login" class="navbar-login">Iniciar sesión</a>
        <a href="/users/register" class="btn btn-primary btn-sm">Registrarse</a>
      <% } %>

      <span class="navbar-separator"></span>
      <% if (!userLogged || userLogged.role !== 'admin') { %>
        <a href="/products/cart" class="navbar-cart">
          🛒 Carrito <span class="cart-count"><%= cartCount %></span>
        </a>
      <% } %>

    </div>

  </div>
</header>